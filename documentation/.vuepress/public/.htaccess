<IfModule mod_headers.c>
# Caching

# 1 week for images, videos
<FilesMatch "\.(ico|jpg|jpeg|gif|png|pdf|mp3|mp4)$">
Header set Cache-Control "public, max-age=604800, no-transform"
</FilesMatch>

<FilesMatch "\.(html|htm|xml|txt|xsl|md)$">
Header set Cache-Control "public, max-age=120, must-revalidate"
</FilesMatch>

<FilesMatch "\.(md)$">
Header set Content-Type "text/markdown; charset=UTF-8"
</FilesMatch>

</IfModule>

# Content negotiation: prefer HTML by default for extensionless URLs.
# Markdown is a fallback variant (low source quality), so browsers get .html
# and only clients explicitly requesting text/markdown receive the .md variant.
<IfModule mod_mime.c>
AddType text/html .html
AddType "text/markdown;qs=0.4" .md
</IfModule> 