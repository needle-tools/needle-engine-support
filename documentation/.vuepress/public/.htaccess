<IfModule mod_headers.c>
# Caching

# 1 week for images, videos
<FilesMatch "\.(ico|jpg|jpeg|gif|png|pdf|mp3|mp4)$">
Header set Cache-Control "public, max-age=604800, no-transform"
</FilesMatch>

<FilesMatch "\.(html|htm|xml|txt|xsl|md)$">
Header set Cache-Control "public, max-age=120, must-revalidate"
</FilesMatch>

<FilesMatch "\.(md)$">
Header set Content-Type "text/markdown; charset=UTF-8"
</FilesMatch>

</IfModule>

# Extensionless URLs always resolve to HTML — no content negotiation.
# Disabling MultiViews removes the .html/.md ambiguity entirely, so an
# extensionless URL has exactly one variant. This makes responses safely
# cacheable behind Cloudflare (which ignores `Vary: accept`) and removes the
# "first fetch wins" race. Markdown stays reachable at its explicit .md URL
# (discoverable via llms.txt and the .md sibling convention) for AI agents.
Options -MultiViews

<IfModule mod_rewrite.c>
RewriteEngine On

# Serve foo.html for an extensionless request to /foo, when foo.html exists.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

<IfModule mod_mime.c>
AddType text/markdown .md
</IfModule> 